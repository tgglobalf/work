        --bg-light: #F9FAFB;
        --border-color: #E5E7EB;
        --success-color: #10B981;
    }

    .bp-landing-section {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
        line-height: 1.6;
        padding: 80px 20px;
        background-color: #ffffff;
    }

    .bp-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .bp-text-center { text-align: center; }
    
    .bp-badge {
        display: inline-block;
        padding: 6px 16px;
        background-color: #EEF2F6;
        color: var(--primary-color);
        font-weight: 600;
        font-size: 14px;
        border-radius: 100px;
        margin-bottom: 20px;
    }

    h1.bp-title {
        font-size: 42px;
        line-height: 1.2;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 24px;
        color: var(--text-main);
    }

    h2.bp-section-title {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-bottom: 16px;
        color: var(--text-main);
    }

    .bp-subtitle {
        font-size: 18px;
        color: var(--text-muted);
        max-width: 800px;
        margin: 0 auto 40px auto;
    }

    /* Кнопки */
    .bp-btn {
        display: inline-block;
        background-color: var(--primary-color);
        color: #ffffff;
        font-weight: 600;
        font-size: 16px;
        padding: 16px 36px;
        border-radius: 8px;
        text-decoration: none;
        transition: background-color 0.2s ease;
        box-shadow: 0 4px 6px -1px rgba(124, 58, 237, 0.1), 0 2px 4px -1px rgba(124, 58, 237, 0.06);
    }

    .bp-btn:hover {
        background-color: var(--primary-hover);
    }

    .bp-btn-hint {
        display: block;
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 12px;
    }

    /* Сетка фич */
    .bp-grid-4 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
        margin-top: 50px;
    }

    .bp-feature-card {
        padding: 30px;
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        transition: transform 0.2s ease;
    }

    .bp-feature-card:hover {
        transform: translateY(-4px);
    }

    .bp-feature-card h3 {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    /* Таблица тарифов */
    .bp-table-wrapper {
        overflow-x: auto;
        margin-top: 40px;
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }

    .bp-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        background-color: #ffffff;
    }

    .bp-table th, .bp-table td {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .bp-table th {
        background-color: var(--bg-light);
        font-weight: 600;
        color: var(--text-main);
    }

    /* FAQ Блок */
    .bp-faq-list {
        max-width: 850px;
        margin: 40px auto 0 auto;
        text-align: left;
    }

    .bp-faq-item {
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .bp-faq-question {
        font-size: 19px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text-main);
    }

    .bp-faq-answer {
        color: var(--text-muted);
        font-size: 16px;
    }

    /* Слайдер до/после имитация */
    .bp-slider-mock {
        width: 100%;
        max-width: 700px;
        height: 400px;
        margin: 40px auto;
        background: #E5E7EB;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    @media(max-width: 768px) {
        h1.bp-title { font-size: 32px; }
        h2.bp-section-title { font-size: 26px; }
        .bp-landing-section { padding: 50px 16px; }
    }
</style>

