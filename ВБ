                grid-template-columns: 50px 1fr;
            }

            .step-number {
                width: 50px;
                height: 50px;
                font-size: 20px;
            }

            .hero-buttons {
                flex-direction: column;
            }

            button {
                width: 100%;
            }
        }
    </style>
</head>
